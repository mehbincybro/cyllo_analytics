<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="cyllo_analytics.DeleteDialog">
        <Dialog title="props.title" size="'sm'">
            <t t-out="props.body"/>
            <t t-set-slot="footer">
                <button class="btn btn-primary"
                        t-on-click="_confirm">Confirm</button>
                <button class="btn btn-secondary"
                        t-on-click="_cancel">Close</button>
            </t>
        </Dialog>
    </t>
</templates>
